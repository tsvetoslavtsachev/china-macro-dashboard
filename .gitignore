# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Secrets (НИКОГА не commit-вай — API ключове)
.env
.env.*
!.env.example

# Cache и data (локални)
data/cache_*.json
data/test_cache_*.json

# Output (генерирани файлове — не commit-ваме)
# Ако искаш да commit-ваш briefing-ите, закоментирай следните редове:
# output/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# ─── Journal content (framework-only is public; notes are private) ──────────
# Виж journal/HOWTO.md за обосновката. .gitkeep файловете пазят празните topic
# папки в git; самите записи остават локални.
journal/**/*.md
!journal/_template.md
!journal/HOWTO.md
# Авто-генерираният индекс има частни заглавия — само локално.
journal/README.md
