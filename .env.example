# Копирай в .env (gitignored) и попълни. Всички са ОПЦИОНАЛНИ.
# Public API-тата работят и без тези стойности.

# DBnomics — public v22 API е отворен (работи без ключ). Ключът е само за
# по-висок rate-limit под тежко натоварване (свободна регистрация на db.nomics.world).
DBNOMICS_API_KEY=dbn_ak_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Override-и на base URL (рядко нужни):
# WORLDBANK_API_BASE=https://api.worldbank.org/v2
# DBNOMICS_API_BASE=https://api.db.nomics.world/v22
